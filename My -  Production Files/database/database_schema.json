{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DreamCollege Industrial Database Schema V2.0",
  "type": "object",
  "required": [
    "cds_meta",
    "cds_admissions",
    "cds_academics",
    "cds_financials",
    "cds_outcomes"
  ],
  "properties": {
    "cds_meta": {
      "type": "object",
      "required": ["school_name", "ipeds_id", "cds_year", "confidence", "source_filename", "mailing_address", "city", "state", "website"],
      "properties": {
        "school_name": { "type": "string" },
        "ipeds_id": { "type": "string" },
        "cds_year": { "type": "string" },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "source_filename": { "type": "string" },
        "mailing_address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zip": { "type": "string" },
        "country": { "type": "string" },
        "website": { "type": "string" },
        "missing_sections": { "type": "array", "items": { "type": "string" } }
      }
    },
    "cds_admissions": {
      "type": "object",
      "properties": {
        "class_size": {
          "type": "object",
          "properties": {
            "applicants_total": { "type": "integer" },
            "admitted_total": { "type": "integer" },
            "enrolled_total": { "type": "integer" },
            "acceptance_rate": { "type": "number" },
            "yield_rate": { "type": "number" }
          }
        },
        "early_programs": {
          "type": "object",
          "properties": {
            "early_decision": {
              "type": "object",
              "properties": { "offered": { "type": "boolean" } }
            },
            "early_action": {
              "type": "object",
              "properties": {
                "offered": { "type": "boolean" },
                "restrictive": { "type": "boolean" },
                "deadline": { "type": "string", "nullable": true },
                "notification_date": { "type": "string", "nullable": true }
              }
            }
          }
        },
        "factors": {
          "type": "object",
          "properties": {
            "rigor_of_secondary_record": { "type": "string" },
            "class_rank": { "type": "string" },
            "academic_gpa": { "type": "string" },
            "standardized_test_scores": { "type": "string" },
            "application_essay": { "type": "string" },
            "recommendation": { "type": "string" },
            "interview": { "type": "string" },
            "extracurricular_activities": { "type": "string" },
            "talent_ability": { "type": "string" },
            "character_personal_qualities": { "type": "string" },
            "first_generation": { "type": "string" },
            "alumni_relation": { "type": "string" },
            "geographical_residence": { "type": "string" },
            "state_residency": { "type": "string" },
            "religious_affiliation": { "type": "string" },
            "volunteer_work": { "type": "string" },
            "work_experience": { "type": "string" },
            "level_of_applicant_interest": { "type": "string" }
          }
        },
        "test_scores": {
          "type": "object",
          "properties": {
            "test_policy": { "type": "string" },
            "sat_composite_25th": { "type": ["integer", "null"] },
            "sat_composite_75th": { "type": ["integer", "null"] },
            "sat_erw_25th": { "type": ["integer", "null"] },
            "sat_erw_75th": { "type": ["integer", "null"] },
            "sat_math_25th": { "type": ["integer", "null"] },
            "sat_math_75th": { "type": ["integer", "null"] },
            "act_composite_25th": { "type": ["integer", "null"] },
            "act_composite_75th": { "type": ["integer", "null"] },
            "pct_submitting_sat": { "type": ["number", "null"] },
            "pct_submitting_act": { "type": ["number", "null"] }
          }
        },
        "gpa_distribution": {
          "type": "object",
          "properties": {
            "avg_gpa": { "type": ["number", "null"] },
            "gpa_weighted": { "type": ["boolean", "null"] },
            "gpa_4_0_and_above": { "type": ["number", "null"] },
            "gpa_3_75_to_3_99": { "type": ["number", "null"] },
            "gpa_3_50_to_3_74": { "type": ["number", "null"] },
            "gpa_3_25_to_3_49": { "type": ["number", "null"] },
            "gpa_3_0_to_3_24": { "type": ["number", "null"] }
          }
        }
      }
    },
    "cds_academics": {
      "type": "object",
      "properties": {
        "student_faculty_ratio": { "type": ["integer", "null"] },
        "institution_type": { "type": ["string", "null"] },
        "setting": { "type": ["string", "null"] },
        "undergrad_enrollment": { "type": ["integer", "null"] },
        "pct_freshmen_on_campus": { "type": ["number", "null"] }
      }
    },
    "cds_financials": {
      "type": "object",
      "properties": {
        "expenses": {
          "type": "object",
          "properties": {
            "tuition_outofstate": { "type": ["integer", "null"] },
            "tuition_instate": { "type": ["integer", "null"] },
            "room_and_board": { "type": ["integer", "null"] },
            "total_coa_outofstate": { "type": ["integer", "null"] },
            "total_coa_instate": { "type": ["integer", "null"] },
            "required_fees": { "type": ["integer", "null"] },
            "books_supplies": { "type": ["integer", "null"] },
            "transportation": { "type": ["integer", "string", "null"] },
            "other_expenses": { "type": ["integer", "null"] }
          }
        },
        "financial_aid": {
          "type": "object",
          "properties": {
            "pct_need_fully_met": { "type": ["number", "null"] },
            "avg_need_based_aid_package": { "type": ["integer", "null"] },
            "avg_need_based_scholarship": { "type": ["integer", "null"] },
            "avg_need_based_loan": { "type": ["integer", "null"] },
            "pct_freshmen_with_need": { "type": ["number", "null"] },
            "aid_policy_note": { "type": ["string", "null"] }
          }
        }
      }
    },
    "cds_outcomes": {
      "type": "object",
      "properties": {
        "retention_rate_fulltime": { "type": ["number", "null"] },
        "grad_rate_6yr": { "type": ["number", "null"] },
        "grad_rate_4yr": { "type": ["number", "null"] }
      }
    }
  }
}

# Server
PORT=8080
NODE_ENV=development

# Auth
API_KEY=dev-key-change-me

# CORS — comma-separated origins. Use * only in dev.
CORS_ORIGIN=*

# SQLite DB file path
DB_PATH=./data/cds.db

# Where ingest reads source JSONs from (absolute or relative to api/)
INGEST_DIR="../College API Design/10 Json files for Universities"

# Swagger UI / OpenAPI docs
DOCS_ENABLED=true
